{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["DOM", "ESNext"],
    "skipLibCheck": true,
    "noUncheckedSideEffectImports": false,
    "types": ["vite/client", "node", "js-md5", "uuid"],
    "composite": true,
    "paths": {
      "@/*": ["./src/*"],
      "@styles/*": ["./src/assets/styles/*"],
      "@comp/*": ["./src/components/*"],
      "@enum/*": ["./src/enum/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@Bili/*": ["./src/plugins/Bili/*"],
      "@Hutao/*": ["./src/plugins/Hutao/*"],
      "@Mys/*": ["./src/plugins/Mys/*"],
      "@Sql/*": ["./src/plugins/Sqlite/*"],
      "@Sqlm/*": ["./src/plugins/Sqlite/modules/*"],
      "@req/*": ["./src/request/*"],
      "@store/*": ["./src/store/modules/*"],
      "@utils/*": ["./src/utils/*"]
    }
  },
  "include": [
    "*.yml",
    "*.yaml",
    "package.json",
    "src/vite-env.d.ts",
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.vue",
    "src/**/*.scss",
    "src/App.vue",
    "src/data/**/*.json",
    "scripts/*.ts",
    "tsconfig.json",
    "vite.config.ts",
    "eslint.config.mjs",
    ".prettierrc.yml",
    ".stylelintrc.yml",
    "eslint/*.js"
  ],
  "exclude": ["node_modules"]
}
